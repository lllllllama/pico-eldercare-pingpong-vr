    description: "\u5EB7\u590D\u7B80\u5316\u7248\uFF1A\u5750\u59FF\u6216\u7AD9\u59FF\u8F7B\u5FAE\u5DE6\u53F3\u79FB\u52A8\uFF0C\u4E0D\u505A\u5927\u5E45\u5F2F\u8170\u3002"
    steps:
    - stepName: "\u8F7B\u79FB\u5411\u5DE6"
      instruction: "\u8EAB\u4F53\u91CD\u5FC3\u8F7B\u5FAE\u5411\u5DE6\u79FB\u52A8\uFF0C\u4FDD\u6301\u5934\u90E8\u7A33\u5B9A"
