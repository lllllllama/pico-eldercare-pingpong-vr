    description: "\u5EB7\u590D\u7B80\u5316\u7248\uFF1A\u53EA\u505A\u7F13\u6162\u5DE6\u53F3\u8F6C\u5934\uFF0C\u4E0D\u8981\u6C42\u6781\u9650\u56DE\u5934\u3002"
    steps:
    - stepName: "\u5411\u5DE6\u8F6C\u5934"
      instruction: "\u5934\u90E8\u7F13\u6162\u5411\u5DE6\u8F6C\uFF0C\u4FDD\u6301\u8212\u9002\u89D2\u5EA6"
